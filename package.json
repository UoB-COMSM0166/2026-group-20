{
    "name": "my-paint-app",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "prettier": "prettier --write ./*.js src/**/*.js tests/**/.js",
        "lint": "eslint src/**/*.js",
        "test": "vitest run",
        "build": "vite build",
        "run-all": "npm run prettier && npm run lint && npm run test && npm run build",
        "preview": "vite preview",
        "prepare": "husky"
    },
    "dependencies": {
        "p5": "^1.11.11"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-jsdoc": "^62.7.1",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "prettier": "3.8.1",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    }
}
